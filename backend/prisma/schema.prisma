generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {
  id        String   @id @default(uuid())
  name      String
  mimeType  String
  size      Int
  key       String   @unique
  createdAt DateTime @default(now())

  @@map("documents")
}